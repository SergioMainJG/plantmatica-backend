    "@nestjs/platform-fastify": "^11.1.26",
    "arktype": "^2.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "temporal-polyfill": "^0.3.2",
    "uuid": "^14.0.0"
