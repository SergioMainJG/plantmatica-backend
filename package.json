{
  "name": "plantmatica-backend",
  "version": "1.2.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start:prod": "bun dist/presentation/main.js",
    "prebuild": "rimraf dist",
    "start": "docker compose up -d && sleep 30 && bun x nest start --exec bun",
    "start:dev": "bun x nest start --watch --exec bun",
    "start:debug": "bun x nest start --debug --watch --exec bun",
    "build": "bun x nest build",
    "benchmark:stress": "bun x node benchmarks/stress.bench.js",
    "benchmark:full": "bun x node benchmarks/full-benchmark.bench.js",
    "benchmark:comprehensive": "bun x node benchmarks/comprehensive-benchmark.js",
    "benchmark:micro": "bun x node benchmarks/validacion.bench.js",
    "benchmark:monitor": "bun x node benchmarks/monitor-sources.bench.js",
    "benchmark:block": "bun x node benchmarks/detect-block.bench.js",
    "benchmark:all": "npm run benchmark:micro && npm run benchmark:stress && npm run benchmark:full",
    "drizzle:changes": "bunx drizzle-kit generate --config='src/infrastructure/drizzle/drizzle.config.ts' && bunx drizzle-kit push --config='src/infrastructure/drizzle/drizzle.config.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/addRian0-0/5IV9-PlantMatica-Backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/addRian0-0/5IV9-PlantMatica-Backend/issues"
  },
  "homepage": "https://github.com/addRian0-0/5IV9-PlantMatica-Backend#readme",
  "devDependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "autocannon": "^8.0.0",
    "benchmark": "^2.1.4",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@fastify/csrf-protection": "^8.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "arktype": "^2.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "temporal-polyfill": "^0.3.2",
    "uuid": "^14.0.0"
  }
}
