  "devDependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "autocannon": "^8.0.0",
    "benchmark": "^2.1.4",
    "drizzle-kit": "^0.31.10"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "bun": ">=1.3.14"
  },
