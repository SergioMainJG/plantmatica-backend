{
  "name": "plantmatica-backend",
  "version": "1.2.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "bun x nest start --exec bun",
    "benchmark:stress": "bun x node benchmarks/stress.bench.js",
    "benchmark:full": "bun x node benchmarks/full-benchmark.bench.js",
    "benchmark:comprehensive": "bun x node benchmarks/comprehensive-benchmark.js",
    "benchmark:micro": "bun x node benchmarks/validacion.bench.js",
    "benchmark:monitor": "bun x node benchmarks/monitor-sources.bench.js",
    "benchmark:block": "bun x node benchmarks/detect-block.bench.js",
    "benchmark:all": "npm run benchmark:micro && npm run benchmark:stress && npm run benchmark:full",
    "prebuild": "rimraf dist",
    "build": "bun x nest build",
    "start:dev": "bun x nest start --watch --exec bun",
    "start:debug": "bun x nest start --debug --watch --exec bun",
    "start:prod": "bun dist/presentation/main.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/addRian0-0/5IV9-PlantMatica-Backend.git"
